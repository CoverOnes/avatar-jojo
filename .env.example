# avatar-jojo env template — copy to .env.local and fill real values (.env.local is gitignored)
# LiveKit Cloud (project 'coverones') — get from `lk project list` / LiveKit Cloud dashboard
LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=REPLACE_ME
LIVEKIT_API_SECRET=REPLACE_ME

# avatar control API
AVATAR_API_PORT=8080

# §24.1 gateway trust boundary (empty = dev short-circuit; set in staging/prod, >=32 chars)
GATEWAY_HMAC_SECRET=

# §24.1 replay-nonce Redis (empty = no replay check; set in staging/prod)
# Convention: dedicated DB index, e.g. redis://localhost:6379/3
GATEWAY_NONCE_REDIS_URL=

# avatar S2S identity (on-behalf-of calls to Go services)
AVATAR_S2S_SERVICE_ID=avatar
AVATAR_S2S_TOKEN=REPLACE_ME
